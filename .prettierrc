{
  "arrowParens": "always",
  "printWidth": 80,
  "singleQuote": false,
  "jsxSingleQuote": false,
  "semi": true,
  "trailingComma": "all",
  "tabWidth": 2,
  "plugins": [
    "prettier-plugin-tailwindcss",
    "prettier-plugin-package-perfection"
  ],
  "tailwindConfig": "./tailwind.config.ts"
}
